# Configuración de Base de Datos
# Use postgresql://usuario:contraseña@host:puerto/nombre_bd para PostgreSQL
# O sqlite:///./melomecate.db para SQLite local
DATABASE_URL=sqlite:///./melomecate.db

# Configuración de Seguridad
# Clave Fernet de 32 bytes codificada en base64 para cifrar las cookies de sesión.
# Puedes generar una ejecutando: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=I4J72UCXIZZT63B4VOW3HS24KXZRHNR2_REPLACE_THIS_WITH_GENERATED_KEY=

# Clave de la API de Gemini (Opcional, para clasificador avanzado)
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# Configuración de WhatsApp Cloud API
WHATSAPP_TOKEN=tu_token_de_whatsapp_aqui
WHATSAPP_VERIFY_TOKEN=tu_token_de_verificacion_de_webhook_aqui
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui
